{
  "name": "claude-irv",
  "version": "1.1.0",
  "description": "Irvine's personal Claude Code plugin with development commands, specialized AI agents, and reusable skills",
  "author": {
    "name": "Andrew Irvine"
  },
  "license": "MIT",
  "commands": [
    ".claude/commands/new-task.md",
    ".claude/commands/misc/feature-plan.md",
    ".claude/commands/misc/lint.md",
    ".claude/commands/misc/docs-generate.md",
    ".claude/commands/ui/component-new.md"
  ],
  "agents": ".claude/agents/",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "description": "Access up-to-date documentation for any library"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "description": "Browser automation and web testing capabilities"
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase"],
      "description": "Supabase database operations and management"
    }
  },
  "tags": [
    "productivity",
    "nextjs",
    "supabase",
    "typescript",
    "react",
    "api",
    "development",
    "mcp",
    "spring-boot",
    "java",
    "devops",
    "docker",
    "kubernetes",
    "code-review"
  ]
}
